# Boopy Assistant — Pro-only in-app chat (/api/chat) using Vercel AI SDK (streamText + tools).
# Production (strict / non-preview Vercel): requires OPENAI_API_KEY for a stable paid default. Dev/preview may use Groq only.
#
# LLM router: optional BOOPY_LLM_ROUTER = comma-separated providers tried in order (ping failover between models).
# Providers: openai | groq | openai_compat (aliases: custom, compat, vps, ollama).
# If unset: defaults to openai → groq → openai_compat (each segment skipped if not configured).
BOOPY_LLM_ROUTER=
GROQ_API_KEY=
# e.g. llama-3.3-70b-versatile, openai/gpt-oss-20b, llama-3.1-8b-instant (see Groq docs)
GROQ_CHAT_MODEL=
# Comma-separated Groq model ids tried in order within the groq router segment.
GROQ_MODEL_CHAIN=
# 1 = only Groq (no OpenAI / compat), for strict free-tier deployments
BOOPY_CHAT_FREE_MODE=
# 1 = skip pre-stream model ping (faster; uses first candidate only)
BOOPY_CHAT_SKIP_MODEL_PING=
# Legacy: when BOOPY_LLM_ROUTER is unset, groq|openai locks default order to that provider only.
BOOPY_CHAT_PROVIDER=
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=
# Comma-separated OpenAI model ids tried in order within the openai router segment (same API key).
OPENAI_CHAT_MODEL_CHAIN=
# Self-hosted OpenAI-compatible API (Ollama http://host:11434/v1 , vLLM, LiteLLM, etc.)
BOOPY_OPENAI_COMPAT_BASE_URL=
BOOPY_OPENAI_COMPAT_API_KEY=
BOOPY_OPENAI_COMPAT_MODEL=
BOOPY_OPENAI_COMPAT_MODEL_CHAIN=

# AI chat (apps/chat — npm run dev:chat, default http://localhost:3002)
# Copy apps/chat/.env.example into apps/chat/.env.local or set these in the repo root .env
NEXT_PUBLIC_AUTH_GITHUB=false
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Marketing app
NEXT_PUBLIC_DASHBOARD_URL=https://app.boopy.dev/login
PAYLOAD_API_URL=
PAYLOAD_API_TOKEN=
PAYLOAD_SECRET=
DATABASE_URI=file:./apps/marketing/payload.db
DATABASE_URL=
PAYLOAD_SQLITE_PATH=
# App (must match the public URL of this deploy — used in Supabase sign-up confirmation emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: hCaptcha site key when Supabase Auth CAPTCHA is enabled (see Supabase → Authentication → Bot and abuse protection)
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=Boopy <no-reply@yourdomain.com>

# Web Push
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry
SENTRY_AUTH_TOKEN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Axiom
AXIOM_TOKEN=
AXIOM_DATASET=

